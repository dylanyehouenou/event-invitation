# ─── Google Sheets ────────────────────────────────────────────
# 1. Créez un projet sur https://console.cloud.google.com
# 2. Activez l'API "Google Sheets API"
# 3. Créez un compte de service (IAM > Comptes de service)
# 4. Générez une clé JSON pour ce compte de service
# 5. Partagez votre Google Sheet avec l'email du compte de service (éditeur)
# 6. Copiez les valeurs ci-dessous depuis le fichier JSON de la clé

# Email du compte de service (champ "client_email" dans le JSON)
GOOGLE_SERVICE_ACCOUNT_EMAIL=mon-service@mon-projet.iam.gserviceaccount.com

# Clé privée (champ "private_key" dans le JSON — gardez les \n littéraux)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ID du Google Sheet (dans l'URL : docs.google.com/spreadsheets/d/[ID]/edit)
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
